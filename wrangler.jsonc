{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "llm-chat-app-templatewebb",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-04",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "ai": {
    "binding": "AI"
  },
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "f3460b3824334eed9df13363970e77e6"
    }
  ]
}
